# Copy to .env and adjust. All optional — defaults come from config/default.yaml.

# Path to a config file (defaults to config/default.yaml)
# EDGEPONG_CONFIG=config/default.yaml

# sim | hardware
EDGEPONG_HARDWARE_MODE=sim

# Logging
EDGEPONG_LOG_LEVEL=INFO

# Networking
EDGEPONG_HTTP_PORT=8080
EDGEPONG_TELEMETRY_PORT=46000
EDGEPONG_COMMAND_PORT=46001
# Paddle IP for haptic commands. Use "auto" to learn it from incoming telemetry.
EDGEPONG_COMMAND_HOST=127.0.0.1
