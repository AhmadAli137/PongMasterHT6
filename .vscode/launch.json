{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug backend (sim)",
      "type": "debugpy",
      "request": "launch",
      "module": "edgepong.main",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug headless demo",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/scripts/headless_demo.py",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "${file}"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
